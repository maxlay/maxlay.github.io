<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title> 🔞 ✖.com 视频🔞 </title>
    <!-- 引入 Flatpickr 样式 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <style>
        :root {
            --bg-color: #1a1a1a;
            --card-bg: #2d2d2d;
            --text-main: #ffffff;
            --text-sub: #aaaaaa;
            --accent: #1db954;
            --hover: #3d3d3d;
            --progress-bg: #444;
            --btn-disabled: #2a2a2a;
            --danger: #ff4444;
            --warning: #ffbb33;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 15px;
            -webkit-tap-highlight-color: transparent;
        }

        /* --- 密码保护 --- */
        #login-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.95); display: flex; justify-content: center;
            align-items: center; z-index: 99999; backdrop-filter: blur(5px);
        }
        .login-box {
            background: var(--card-bg); padding: 30px 20px; border-radius: 12px;
            text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            width: 85%; max-width: 320px; border: 1px solid #444;
        }
        .login-box h2 { margin-top: 0; font-size: 1.2rem; margin-bottom: 20px; }
        .login-input {
            width: 100%; padding: 14px; margin-bottom: 15px; background: #1a1a1a;
            border: 1px solid #555; color: white; border-radius: 8px;
            font-size: 16px; text-align: center; box-sizing: border-box; outline: none;
        }
        .login-input:focus { border-color: var(--accent); }
        .login-btn {
            width: 100%; padding: 14px; background-color: var(--accent); color: white;
            border: none; border-radius: 8px; font-size: 16px; cursor: pointer; font-weight: bold;
        }
        .login-error { color: #ff4444; font-size: 14px; margin-top: 15px; display: none; }

        /* --- 头部统计 --- */
        .header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 15px; flex-wrap: nowrap; overflow: hidden;
            padding-bottom: 10px; border-bottom: 1px solid #333;
        }
        .stats-container {
            display: flex; align-items: center; gap: 10px; white-space: nowrap;
            overflow: hidden; flex-shrink: 1; width: 100%;
        }
        .stats-main { 
            font-size: 0.9rem; color: var(--text-main); font-weight: 600; flex-shrink: 0; 
        }
        .stats-sub {
            font-size: 0.8rem;
            color: var(--accent); font-weight: 600;
            background: rgba(29, 185, 84, 0.1);
            padding: 4px 8px; border-radius: 6px;
            cursor: pointer; border: 1px solid rgba(29, 185, 84, 0.3);
            flex-shrink: 0; overflow: hidden; text-overflow: ellipsis;
            transition: all 0.2s;
        }
        .stats-sub:hover { background: rgba(29, 185, 84, 0.25); }

        /* --- 进度条 --- */
        .progress-container {
            width: 100%; height: 4px; background-color: var(--progress-bg);
            border-radius: 2px; margin: 10px 0 15px 0; overflow: hidden;
            display: none; position: relative;
        }
        .progress-container.active { display: block; }
        .progress-bar {
            height: 100%; background-color: var(--accent); width: 0%;
            transition: width 0.3s ease-out;
        }
        .progress-text {
            position: absolute; right: 0; top: -18px;
            font-size: 10px; color: var(--text-sub);
        }

        /* --- 视频网格 --- */
        .grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }
        
        .card {
            background: var(--card-bg); border-radius: 6px; overflow: hidden;
            cursor: pointer; transition: transform 0.2s;
            position: relative; text-decoration: none; color: inherit; display: block;
        }
        .card:active { transform: scale(0.98); }
        .card:hover { transform: translateY(-4px); box-shadow: 0 8px 16px rgba(0,0,0,0.4); }
        
        .thumb-container {
            position: relative; width: 100%; 
            padding-top: 177.77%;
            background: #000;
        }
        
        .thumb-img {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;
        }
        .play-overlay {
            position: absolute; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.3); display: flex; align-items: center;
            justify-content: center; opacity: 0; transition: opacity 0.2s;
        }
        .card:hover .play-overlay { opacity: 1; }
        .play-icon {
            font-size: 24px; color: white; background: rgba(0,0,0,0.6);
            border-radius: 50%; width: 40px; height: 40px;
            display: flex; align-items: center; justify-content: center;
            border: 2px solid white;
        }
        .duration-badge {
            position: absolute; bottom: 4px; right: 4px;
            background: rgba(0,0,0,0.85); color: white;
            padding: 2px 4px; border-radius: 3px; font-size: 10px; font-weight: bold; z-index: 2;
        }
        .info { padding: 8px; }
        .title {
            font-size: 12px; font-weight: 600; margin-bottom: 4px;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .meta {
            font-size: 10px; color: var(--text-sub);
            display: flex; justify-content: space-between;
        }

        /* --- 分页控件 (三等分布局) --- */
        .pagination {
            display: flex; 
            justify-content: space-between; 
            gap: 6px;
            margin-top: 15px; 
            align-items: stretch;
            flex-wrap: nowrap;
            width: 100%;
            position: relative;
        }
        
        #top-pagination { margin-top: 0; margin-bottom: 15px; }

        .page-btn {
            background: var(--card-bg); border: 1px solid #555;
            color: white; padding: 6px 4px; border-radius: 5px;
            cursor: pointer; transition: 0.2s; font-weight: 500;
            display: flex; align-items: center; justify-content: center;
            flex: 1; /* 三等分关键 */
            font-size: 0.8rem;
            min-height: 40px;
            text-align: center;
            overflow: hidden;
            white-space: nowrap;
        }
        .page-btn:hover:not(:disabled) { 
            background: var(--accent); border-color: var(--accent); 
            transform: translateY(-2px);
        }
        .page-btn:disabled { 
            opacity: 0.3; cursor: not-allowed; background: var(--btn-disabled); 
            transform: none; border-color: #333;
        }

        .page-info-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 2px;
            background: #222;
            padding: 4px 2px;
            border-radius: 6px;
            border: 1px solid #444;
            flex: 1; /* 三等分关键 */
            min-width: 0;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
            cursor: pointer;
            position: relative;
            z-index: 10;
            overflow: hidden;
        }
        
        #date-trigger {
            cursor: default;
            background: #252525;
            border-color: #333;
            box-shadow: none;
        }
        #date-trigger:hover {
            border-color: #333;
            background: #252525;
        }
        #date-trigger::after { content: none; }

        .page-info-container:hover {
            border-color: var(--accent);
            background: #2a2a2a;
        }
        .page-info-container::after {
            content: '📅';
            font-size: 10px;
            position: absolute;
            top: 2px;
            right: 4px;
            opacity: 0.5;
        }

        .page-date {
            font-size: 0.85rem;
            font-weight: bold;
            color: var(--text-main);
            line-height: 1.2;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            width: 100%;
        }

        .page-count {
            font-size: 0.7rem;
            color: var(--accent);
            background: rgba(29, 185, 84, 0.15);
            padding: 1px 4px;
            border-radius: 8px;
            font-weight: 600;
            white-space: nowrap;
        }

        .loading { text-align: center; padding: 40px; color: var(--text-sub); font-size: 14px; }
        .error { color: #ff4444; text-align: center; padding: 20px; }
        
        @media (min-width: 768px) {
            body { padding: 20px 40px; }
            .stats-main { font-size: 1.1rem; }
            .stats-sub { font-size: 0.95rem; padding: 4px 12px; }
            .grid { grid-template-columns: repeat(4, 1fr); gap: 15px; }
            .pagination { justify-content: center; gap: 15px; max-width: 800px; margin-left: auto; margin-right: auto; }
            .page-btn { max-width: 180px; padding: 10px 15px; font-size: 0.95rem; }
            .page-info-container { flex-direction: row; gap: 12px; padding: 10px 20px; max-width: 250px; }
            .page-info-container::after { content: none; }
            .page-date { font-size: 1.1rem; white-space: normal; }
            .page-count { font-size: 0.9rem; }
        }

        @media (min-width: 1400px) {
            .grid { grid-template-columns: repeat(6, 1fr); gap: 18px; }
            .card:hover { transform: translateY(-6px); }
            .play-icon { width: 50px; height: 50px; font-size: 32px; }
            .title { font-size: 14px; }
            .meta { font-size: 12px; }
        }

        .flatpickr-calendar {
            background: #2d2d2d !important;
            border: 1px solid #444 !important;
            box-shadow: 0 10px 30px rgba(0,0,0,0.6) !important;
            border-radius: 8px !important;
            position: fixed !important;
            top: 120px !important;
            left: 50% !important;
            transform: translateX(-50%) !important;
            right: auto !important;
            bottom: auto !important;
            margin: 0 !important;
            z-index: 99999 !important;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s;
            display: block; 
        }
        .flatpickr-calendar.open { opacity: 1; pointer-events: auto; }
        .flatpickr-calendar.arrowTop::before, .flatpickr-calendar.arrowTop::after,
        .flatpickr-calendar.arrowBottom::before, .flatpickr-calendar.arrowBottom::after { display: none !important; }
        .flatpickr-day { color: #ddd !important; }
        .flatpickr-day:hover { background: #3d3d3d !important; border-color: #3d3d3d !important; }
        .flatpickr-day.selected, .flatpickr-day.startRange, .flatpickr-day.endRange, .flatpickr-day.selected.inRange, .flatpickr-day.startRange.inRange, .flatpickr-day.endRange.inRange, .flatpickr-day.selected:focus, .flatpickr-day.startRange:focus, .flatpickr-day.endRange:focus, .flatpickr-day.selected:hover, .flatpickr-day.startRange:hover, .flatpickr-day.endRange:hover, .flatpickr-day.selected.prevMonthDay, .flatpickr-day.startRange.prevMonthDay, .flatpickr-day.endRange.prevMonthDay, .flatpickr-day.selected.nextMonthDay, .flatpickr-day.startRange.nextMonthDay, .flatpickr-day.endRange.nextMonthDay {
            background: var(--accent) !important; border-color: var(--accent) !important; color: white !important;
        }
        .flatpickr-months .flatpickr-month { background: #2d2d2d !important; color: #ddd !important; fill: #ddd !important; }
        .flatpickr-current-month .flatpickr-monthDropdown-months { color: #ddd !important; background: #222 !important; }
        .flatpickr-current-month input.cur-year { color: #ddd !important; background: #222 !important; }
        .flatpickr-weekdays { background: #222 !important; }
        .flatpickr-weekday { color: #aaa !important; }
        .flatpickr-day.flatpickr-disabled, .flatpickr-day.flatpickr-disabled:hover { color: #555 !important; cursor: not-allowed; }

        /* ================= 账号弹窗 Modal 样式 ================= */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.85); z-index: 100000;
            display: none; justify-content: center; align-items: center;
            opacity: 0; transition: opacity 0.3s ease; backdrop-filter: blur(5px);
        }
        .modal-overlay.active { display: flex; opacity: 1; }
        .modal-content {
            background: var(--bg-color); width: 90%; max-width: 1200px; height: 90%;
            border-radius: 12px; position: relative; display: flex;
            flex-direction: column; overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.6); border: 1px solid #444;
        }
        
        /* 修改：弹窗标题栏三等分布局 */
        .modal-header {
            padding: 15px 20px; border-bottom: 1px solid #333;
            display: flex; justify-content: space-between; align-items: center;
            background: var(--card-bg); flex-shrink: 0;
            gap: 10px;
        }

        .modal-actions-left {
            display: flex;
            gap: 10px;
            flex: 1; /* 左侧占 1/3 */
            justify-content: flex-start;
        }

        .modal-title-group {
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 1; /* 中间占 1/3 */
            overflow: hidden;
            text-align: center;
        }

        .modal-title {
            font-size: 1.1rem; font-weight: bold; color: var(--text-main);
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
            max-width: 100%;
        }
        
        .modal-count {
            color: var(--text-sub);
            font-weight: normal;
            font-size: 1rem;
            margin-left: 4px;
        }

        .modal-actions-right {
            display: flex;
            gap: 10px;
            flex: 1; /* 右侧占 1/3 */
            justify-content: flex-end;
        }

        .action-icon-btn {
            background: transparent; border: 1px solid #555; color: var(--text-sub);
            width: 36px; height: 36px; border-radius: 6px; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; transition: all 0.2s;
        }
        .action-icon-btn:hover { color: white; border-color: white; background: rgba(255,255,255,0.1); }
        .action-icon-btn.active-fav { color: var(--warning); border-color: var(--warning); background: rgba(255, 187, 51, 0.1); }
        .action-icon-btn.active-bin { color: var(--danger); border-color: var(--danger); background: rgba(255, 68, 68, 0.1); }
        
        .modal-close {
            background: transparent; border: none; color: var(--text-sub);
            font-size: 24px; cursor: pointer; padding: 0 5px; line-height: 1;
            transition: color 0.2s;
        }
        .modal-close:hover { color: var(--text-main); }

        .modal-body {
            flex: 1; overflow-y: auto; padding: 15px;
            scrollbar-width: thin; scrollbar-color: var(--accent) var(--bg-color);
        }
        .modal-body::-webkit-scrollbar { width: 8px; }
        .modal-body::-webkit-scrollbar-track { background: var(--bg-color); }
        .modal-body::-webkit-scrollbar-thumb { background-color: var(--accent); border-radius: 4px; }

        .waterfall-container { column-count: 2; column-gap: 10px; }
        .waterfall-item {
            break-inside: avoid; margin-bottom: 10px; background: var(--card-bg);
            border-radius: 6px; overflow: hidden; cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s; position: relative;
        }
        .waterfall-item:hover { transform: translateY(-4px); box-shadow: 0 8px 16px rgba(0,0,0,0.4); }
        .waterfall-thumb-container { position: relative; width: 100%; background: #000; }
        .waterfall-thumb-img { display: block; width: 100%; height: auto; object-fit: cover; }
        .waterfall-play-overlay {
            position: absolute; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.3); display: flex; align-items: center;
            justify-content: center; opacity: 0; transition: opacity 0.2s;
        }
        .waterfall-item:hover .waterfall-play-overlay { opacity: 1; }
        .waterfall-duration-badge {
            position: absolute; bottom: 4px; right: 4px;
            background: rgba(0,0,0,0.85); color: white;
            padding: 2px 4px; border-radius: 3px; font-size: 10px; font-weight: bold; z-index: 2;
        }
        .waterfall-info { padding: 8px; }
        .waterfall-date { font-size: 10px; color: var(--text-sub); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        @media (min-width: 600px) { .waterfall-container { column-count: 3; column-gap: 15px; } .waterfall-item { margin-bottom: 15px; } }
        @media (min-width: 900px) { .waterfall-container { column-count: 4; column-gap: 15px; } }
        @media (min-width: 1200px) { .waterfall-container { column-count: 5; column-gap: 18px; } }
        
        .account-link {
            color: var(--accent); cursor: pointer; text-decoration: none;
            border-bottom: 1px dashed rgba(29, 185, 84, 0.5); transition: all 0.2s;
        }
        .account-link:hover {
            color: #fff; border-bottom-color: #fff;
            background: rgba(29, 185, 84, 0.1); border-radius: 4px; padding: 0 2px;
        }

        /* ================= 管理弹窗样式 ================= */
        .manager-list-container { display: flex; flex-direction: column; gap: 10px; }
        .manager-item {
            background: var(--card-bg); padding: 12px; border-radius: 8px;
            display: flex; align-items: center; justify-content: space-between;
            border: 1px solid #333; transition: background 0.2s;
        }
        .manager-item:hover { background: #333; }
        .manager-item-info { flex: 1; overflow: hidden; }
        .manager-item-name { font-weight: bold; color: var(--text-main); font-size: 1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .manager-item-actions { display: flex; gap: 8px; margin-left: 10px; flex-shrink: 0; }
        .mgr-btn { padding: 6px 10px; border-radius: 4px; border: none; font-size: 0.8rem; cursor: pointer; color: white; transition: opacity 0.2s; }
        .mgr-btn:hover { opacity: 0.8; }
        .mgr-btn-edit { background: #2196f3; }
        .mgr-btn-del { background: var(--danger); }
        .manager-search-box {
            width: 100%; padding: 12px; background: #1a1a1a; border: 1px solid #444;
            color: white; border-radius: 8px; margin-bottom: 15px; font-size: 16px; box-sizing: border-box;
        }
        .empty-state { text-align: center; color: var(--text-sub); padding: 40px 20px; font-size: 14px; }

        .bottom-manager-buttons { display: flex; gap: 10px; margin-top: 15px; margin-bottom: 30px; }
        .mgr-main-btn {
            flex: 1; padding: 12px; border-radius: 8px; border: 1px solid #444;
            background: var(--card-bg); color: var(--text-main); font-weight: 600;
            font-size: 0.95rem; cursor: pointer; transition: all 0.2s;
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .mgr-main-btn:hover { background: #3d3d3d; border-color: #666; }
        .mgr-main-btn.fav-btn { color: var(--warning); border-color: rgba(255, 187, 51, 0.3); }
        .mgr-main-btn.fav-btn:hover { background: rgba(255, 187, 51, 0.1); border-color: var(--warning); }
        .mgr-main-btn.bin-btn { color: var(--danger); border-color: rgba(255, 68, 68, 0.3); }
        .mgr-main-btn.bin-btn:hover { background: rgba(255, 68, 68, 0.1); border-color: var(--danger); }

    </style>
</head>
<body>

    <div id="login-overlay">
        <div class="login-box">
            <h2>🔒 访问验证</h2>
            <input type="password" id="passwordInput" class="login-input" placeholder="请输入密码" autofocus>
            <button onclick="checkPassword()" class="login-btn">进入</button>
            <p id="loginError" class="login-error">密码错误！</p>
        </div>
    </div>

    <div class="header">
        <div class="stats-container">
            <div class="stats-main" id="stats-total">准备加载...</div>
            <div class="stats-sub" id="stats-newest" style="display:none;" title="点击跳转到最新一页">加载中...</div>
        </div>
    </div>

    <div class="progress-container" id="progress-container">
        <span class="progress-text" id="progress-text">0%</span>
        <div class="progress-bar" id="progress-bar"></div>
    </div>

    <div class="pagination" id="top-pagination" style="display:none;">
        <button class="page-btn" id="top-newer-btn" disabled>最新</button>
        <div class="page-info-container" id="top-date-trigger">
            <span class="page-date" id="top-page-date">--</span>
            <span class="page-count" id="top-page-count">0 部</span>
        </div>
        <button class="page-btn" id="top-older-btn" disabled>最旧</button>
    </div>

    <div id="video-grid" class="grid"></div>
    <div id="loading-msg" class="loading" style="display:none;">正在初始化...</div>

    <div class="pagination" id="pagination" style="display:none;">
        <button class="page-btn" id="newer-btn" disabled>最新</button>
        <div class="page-info-container" id="date-trigger">
            <span class="page-date" id="page-date">--</span>
            <span class="page-count" id="page-count">0 部</span>
        </div>
        <button class="page-btn" id="older-btn" disabled>最旧</button>
    </div>

    <div class="bottom-manager-buttons" id="bottom-manager-buttons" style="display:none;">
        <button class="mgr-main-btn fav-btn" id="btn-open-favorites"><span>⭐</span> 收藏夹</button>
        <button class="mgr-main-btn bin-btn" id="btn-open-recycle"><span>🗑️</span> 回收站</button>
    </div>

    <div id="account-modal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <!-- 左侧操作区 -->
                <div class="modal-actions-left">
                    <button class="action-icon-btn" id="btn-toggle-fav" title="加入收藏/取消收藏">⭐</button>
                    <button class="action-icon-btn" id="btn-toggle-bin" title="加入回收站/还原">🗑️</button>
                </div>
                
                <!-- 中间标题区 -->
                <div class="modal-title-group">
                    <div class="modal-title" id="modal-account-name">账号名称</div>
                </div>
                
                <!-- 右侧关闭区 -->
                <div class="modal-actions-right">
                    <button class="modal-close" id="modal-close-btn">&times;</button>
                </div>
            </div>
            <div class="modal-body">
                <div id="waterfall-list" class="waterfall-container"></div>
            </div>
        </div>
    </div>

    <div id="manager-modal" class="modal-overlay">
        <div class="modal-content" style="max-width: 800px; height: 80%;">
            <div class="modal-header">
                <div class="modal-title" id="manager-modal-title">管理列表</div>
                <button class="modal-close" id="manager-modal-close">&times;</button>
            </div>
            <div class="modal-body">
                <input type="text" id="manager-search-input" class="manager-search-box" placeholder="搜索账号名称...">
                <div id="manager-list-content" class="manager-list-container"></div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/zh.js"></script>

    <script>
        // ================= 密码逻辑 =================
        const CORRECT_PASSWORD = "821025";
        const COOKIE_NAME = "x_video_auth_verified";
        
        function setPermanentCookie(name, value) {
            const date = new Date();
            date.setFullYear(date.getFullYear() + 10);
            document.cookie = `${name}=${encodeURIComponent(value)}; expires=${date.toUTCString()}; path=/; SameSite=Strict`;
        }
        function getCookie(name) {
            const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
            return match ? decodeURIComponent(match[2]) : null;
        }
        function checkPassword() {
            const input = document.getElementById('passwordInput').value;
            if (input === CORRECT_PASSWORD) {
                setPermanentCookie(COOKIE_NAME, "true");
                document.getElementById('login-overlay').style.display = 'none';
                init();
            } else {
                const err = document.getElementById('loginError');
                err.style.display = 'block';
                setTimeout(() => { window.close(); document.body.innerHTML = '<h1 style="color:red;text-align:center">⛔ 拒绝</h1>'; }, 1500);
            }
        }
        document.getElementById('passwordInput').addEventListener('keypress', e => { if(e.key==='Enter') checkPassword(); });
        
        if (getCookie(COOKIE_NAME) === "true") {
            document.getElementById('login-overlay').style.display = 'none';
            setTimeout(init, 50);
        }

        // ================= 核心逻辑 =================
        // 修改：定义基础 URL 和分片数量
        const BASE_URL = 'https://wget.la/https://raw.githubusercontent.com/maxlay/maxlay.github.io/main/twitter-ero-video-ranking/';
        const DATA_PARTS_COUNT = 4;
        
        let allData = [], groupedData = {}, sortedDates = [], currentDateKey = "";
        let fpInstance = null; 

        // ================= 数据存储与管理逻辑 =================
        const STORAGE_KEYS = {
            FAVORITES: 'user_favorites_v1',
            RECYCLE_BIN: 'user_recycle_bin_v1'
        };

        function getStorageList(key) {
            try {
                const data = localStorage.getItem(key);
                return data ? JSON.parse(data) : [];
            } catch (e) { return []; }
        }

        function saveStorageList(key, list) {
            try {
                localStorage.setItem(key, JSON.stringify(list));
                return true;
            } catch (e) { alert("保存失败，存储空间可能已满。"); return false; }
        }

        function addToStorageList(key, item) {
            const list = getStorageList(key);
            if (!list.includes(item)) {
                list.push(item);
                saveStorageList(key, list);
                return true;
            }
            return false;
        }

        function removeFromStorageList(key, item) {
            let list = getStorageList(key);
            const initialLen = list.length;
            list = list.filter(i => i !== item);
            if (list.length !== initialLen) {
                saveStorageList(key, list);
                return true;
            }
            return false;
        }

        function isInStorageList(key, item) {
            return getStorageList(key).includes(item);
        }

        function getAccountId(item) {
            if (item.tweet_account) {
                return item.tweet_account;
            }
            return `ID:${item.id}`;
        }

        let currentModalAccount = null;

        const gridEl = document.getElementById('video-grid');
        const loadingEl = document.getElementById('loading-msg');
        const statsTotalEl = document.getElementById('stats-total');
        const statsNewestEl = document.getElementById('stats-newest');
        
        const newerBtn = document.getElementById('newer-btn');
        const olderBtn = document.getElementById('older-btn');
        const topNewerBtn = document.getElementById('top-newer-btn');
        const topOlderBtn = document.getElementById('top-older-btn');
        const topDateTrigger = document.getElementById('top-date-trigger');

        // ================= 弹窗相关逻辑 =================
        const modalOverlay = document.getElementById('account-modal');
        const modalCloseBtn = document.getElementById('modal-close-btn');
        const modalAccountName = document.getElementById('modal-account-name');
        const waterfallList = document.getElementById('waterfall-list');
        
        const btnToggleFav = document.getElementById('btn-toggle-fav');
        const btnToggleBin = document.getElementById('btn-toggle-bin');

        const managerModal = document.getElementById('manager-modal');
        const managerModalTitle = document.getElementById('manager-modal-title');
        const managerModalClose = document.getElementById('manager-modal-close');
        const managerListContent = document.getElementById('manager-list-content');
        const managerSearchInput = document.getElementById('manager-search-input');
        
        let currentManagerType = null;

        function updateAccountModalButtons() {
            if (!currentModalAccount) return;

            const isFav = isInStorageList(STORAGE_KEYS.FAVORITES, currentModalAccount);
            const isBin = isInStorageList(STORAGE_KEYS.RECYCLE_BIN, currentModalAccount);

            if (isFav) {
                btnToggleFav.classList.add('active-fav');
                btnToggleFav.title = "取消收藏";
            } else {
                btnToggleFav.classList.remove('active-fav');
                btnToggleFav.title = "加入收藏";
            }

            if (isBin) {
                btnToggleBin.classList.add('active-bin');
                btnToggleBin.title = "从回收站还原";
            } else {
                btnToggleBin.classList.remove('active-bin');
                btnToggleBin.title = "加入回收站";
            }
            
            if (isBin && isFav) {
                 removeFromStorageList(STORAGE_KEYS.FAVORITES, currentModalAccount);
                 updateAccountModalButtons();
            }
        }

        function handleToggleFavorite() {
            if (!currentModalAccount) return;
            const isFav = isInStorageList(STORAGE_KEYS.FAVORITES, currentModalAccount);
            
            if (isFav) {
                removeFromStorageList(STORAGE_KEYS.FAVORITES, currentModalAccount);
            } else {
                if (isInStorageList(STORAGE_KEYS.RECYCLE_BIN, currentModalAccount)) {
                    removeFromStorageList(STORAGE_KEYS.RECYCLE_BIN, currentModalAccount);
                }
                addToStorageList(STORAGE_KEYS.FAVORITES, currentModalAccount);
            }
            updateAccountModalButtons();
        }

        function handleToggleRecycle() {
            if (!currentModalAccount) return;
            const isBin = isInStorageList(STORAGE_KEYS.RECYCLE_BIN, currentModalAccount);

            if (isBin) {
                removeFromStorageList(STORAGE_KEYS.RECYCLE_BIN, currentModalAccount);
                alert(`已还原账号: ${currentModalAccount}\n请刷新页面或切换日期以查看该账号视频。`);
            } else {
                if (isInStorageList(STORAGE_KEYS.FAVORITES, currentModalAccount)) {
                    removeFromStorageList(STORAGE_KEYS.FAVORITES, currentModalAccount);
                }
                addToStorageList(STORAGE_KEYS.RECYCLE_BIN, currentModalAccount);
                renderPage(currentDateKey); 
            }
            updateAccountModalButtons();
        }

        function openAccountModal(accountName) {
            if (!accountName) return;
            currentModalAccount = accountName;

            const filteredData = allData.filter(item => {
                const itemId = getAccountId(item);
                return itemId === accountName;
            });

            if (filteredData.length === 0) {
                alert("该账号下暂无视频数据。");
                return;
            }

            filteredData.sort((a, b) => {
                const dateA = new Date(a.posted_at || a.created_at || 0);
                const dateB = new Date(b.posted_at || b.created_at || 0);
                return dateB - dateA;
            });

            modalAccountName.innerHTML = `${accountName} <span class="modal-count">(${filteredData.length})</span>`;

            waterfallList.innerHTML = '';
            filteredData.forEach(item => {
                const div = document.createElement('div');
                div.className = 'waterfall-item';
                
                const m = Math.floor((item.time||0)/60);
                const s = (item.time||0)%60;
                const timeStr = `${m}:${s.toString().padStart(2,'0')}`;
                const dateStr = item.posted_at || item.created_at || '';
                const displayDate = dateStr ? dateStr.substring(0, 10) : '';

                div.innerHTML = `
                    <div class="waterfall-thumb-container">
                        <img class="waterfall-thumb-img" src="${item.thumbnail}" loading="lazy" onerror="this.src='https://via.placeholder.com/300x533?text=No+Image'">
                        <div class="waterfall-duration-badge">${timeStr}</div>
                        <div class="waterfall-play-overlay"><div class="play-icon">▶</div></div>
                    </div>
                    <div class="waterfall-info">
                        <div class="waterfall-date">📅 ${displayDate}</div>
                    </div>
                `;

                div.addEventListener('click', () => {
                    if (item.url) window.open(item.url, '_blank');
                });

                waterfallList.appendChild(div);
            });

            updateAccountModalButtons();
            modalOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeAccountModal() {
            modalOverlay.classList.remove('active');
            document.body.style.overflow = '';
            currentModalAccount = null;
        }

        modalCloseBtn.addEventListener('click', closeAccountModal);
        btnToggleFav.addEventListener('click', handleToggleFavorite);
        btnToggleBin.addEventListener('click', handleToggleRecycle);
        
        modalOverlay.addEventListener('click', (e) => {
            if (e.target === modalOverlay) closeAccountModal();
        });

        // ================= 管理弹窗逻辑 =================
        function openManagerModal(type) {
            currentManagerType = type;
            const isFav = type === 'favorites';
            const storageKey = isFav ? STORAGE_KEYS.FAVORITES : STORAGE_KEYS.RECYCLE_BIN;
            const title = isFav ? "⭐ 收藏夹管理" : "🗑️ 回收站管理";
            const emptyText = isFav ? "收藏夹为空，去视频详情页添加吧！" : "回收站空空如也。";

            managerModalTitle.innerText = title;
            managerSearchInput.value = '';
            managerModal.classList.add('active');
            document.body.style.overflow = 'hidden';
            renderManagerList(storageKey, emptyText);
        }

        function closeManagerModal() {
            managerModal.classList.remove('active');
            document.body.style.overflow = '';
            currentManagerType = null;
        }

        function renderManagerList(storageKey, emptyText) {
            const list = getStorageList(storageKey);
            const searchTerm = managerSearchInput.value.toLowerCase();
            managerListContent.innerHTML = '';
            const filteredList = list.filter(name => name.toLowerCase().includes(searchTerm));

            if (filteredList.length === 0) {
                managerListContent.innerHTML = `<div class="empty-state">${list.length === 0 ? emptyText : '无匹配结果'}</div>`;
                return;
            }

            filteredList.forEach(name => {
                const div = document.createElement('div');
                div.className = 'manager-item';
                
                let actionsHtml = '';
                if (currentManagerType === 'recycleBin') {
                    actionsHtml = `<button class="mgr-btn mgr-btn-edit" onclick="restoreAccount('${name}')">还原</button>`;
                } else {
                    actionsHtml = `<button class="mgr-btn mgr-btn-del" onclick="removeAccountFromList('${name}', '${storageKey}')">删除</button>`;
                }

                div.innerHTML = `
                    <div class="manager-item-info">
                        <div class="manager-item-name">${name.startsWith('ID:') ? name : '@'+name}</div>
                    </div>
                    <div class="manager-item-actions">${actionsHtml}</div>
                `;
                managerListContent.appendChild(div);
            });
        }

        window.removeAccountFromList = function(name, key) {
            removeFromStorageList(key, name);
            renderManagerList(key, key === STORAGE_KEYS.FAVORITES ? "收藏夹为空" : "回收站为空");
        };

        window.restoreAccount = function(name) {
            removeFromStorageList(STORAGE_KEYS.RECYCLE_BIN, name);
            alert(`已还原 ${name.startsWith('ID:') ? name : '@'+name}。请刷新页面或切换日期查看。`);
            renderManagerList(STORAGE_KEYS.RECYCLE_BIN, "回收站为空");
        };

        managerModalClose.addEventListener('click', closeManagerModal);
        managerModal.addEventListener('click', (e) => { if (e.target === managerModal) closeManagerModal(); });
        managerSearchInput.addEventListener('input', () => {
            if (currentManagerType) {
                const key = currentManagerType === 'favorites' ? STORAGE_KEYS.FAVORITES : STORAGE_KEYS.RECYCLE_BIN;
                const emptyText = currentManagerType === 'favorites' ? "收藏夹为空" : "回收站为空";
                renderManagerList(key, emptyText);
            }
        });

        document.getElementById('btn-open-favorites').addEventListener('click', () => openManagerModal('favorites'));
        document.getElementById('btn-open-recycle').addEventListener('click', () => openManagerModal('recycleBin'));

        // ================= 全局键盘快捷键 =================
        document.addEventListener('keydown', (e) => {
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
            const isCalendarOpen = fpInstance && fpInstance.isOpen;
            const isAccountModalOpen = modalOverlay.classList.contains('active');
            const isManagerModalOpen = managerModal.classList.contains('active');

            if ((e.key === 'q' || e.key === 'Q' || e.key === 'Escape')) {
                if (isManagerModalOpen) { closeManagerModal(); return; }
                if (isAccountModalOpen) { closeAccountModal(); return; }
            }
            if (isAccountModalOpen || isManagerModalOpen || isCalendarOpen) return;

            const idx = sortedDates.indexOf(currentDateKey);
            if (idx === -1) return;
            if (e.key === 'ArrowLeft' && idx > 0) renderPage(sortedDates[idx - 1]);
            else if (e.key === 'ArrowRight' && idx < sortedDates.length - 1) renderPage(sortedDates[idx + 1]);
        });

        function formatDateKey(dateStr) {
            if (!dateStr) return "Unknown";
            return dateStr.length >= 10 ? dateStr.substring(0, 10) : "Unknown";
        }

        // ================= 修改：多文件并发加载逻辑 =================
        async function loadData() {
            const progressContainer = document.getElementById('progress-container');
            const progressBar = document.getElementById('progress-bar');
            const progressText = document.getElementById('progress-text');
            
            progressContainer.classList.add('active');
            progressBar.style.width = '0%';
            progressText.innerText = '0%';

            // 构建 4 个文件的 URL 数组
            const fileUrls = Array.from({ length: DATA_PARTS_COUNT }, (_, i) => 
                `${BASE_URL}data-part-${i}.json`
            );

            try {
                // 1. 创建带有进度追踪的 Promise 数组
                const fetchPromises = fileUrls.map((url, index) => {
                    return fetch(url)
                        .then(response => {
                            if (!response.ok) {
                                throw new Error(`分片 ${index + 1}/${DATA_PARTS_COUNT} 加载失败: ${response.status}`);
                            }
                            // 更新进度：请求完成 (50% 权重给请求，50% 给解析，这里简化为请求完即算该分片完成)
                            const progress = Math.round(((index + 1) / DATA_PARTS_COUNT) * 100);
                            progressBar.style.width = `${progress}%`;
                            progressText.innerText = `加载分片 ${index + 1}/${DATA_PARTS_COUNT} (${progress}%)`;
                            return response.json();
                        })
                        .catch(err => {
                            console.error(`分片 ${index + 1} 解析错误:`, err);
                            throw err;
                        });
                });

                // 2. 并发请求所有分片
                const chunks = await Promise.all(fetchPromises);
                
                // 3. 合并数组
                let mergedData = [].concat(...chunks);
                
                console.log(`成功加载 ${mergedData.length} 条数据`);
                progressText.innerText = `数据聚合完成，正在排序...`;

                // 4. 全局再次排序 (确保时间线连续)
                // 假设 created_at 是 ISO 字符串格式，直接 localeCompare 即可，或者转 Date
                mergedData.sort((a, b) => {
                    const dateA = new Date(a.created_at || a.posted_at || 0);
                    const dateB = new Date(b.created_at || b.posted_at || 0);
                    return dateB - dateA; // 降序
                });

                // 5. 赋值给全局变量
                allData = mergedData;
                
                // 6. 数据处理 (分组、过滤回收站)
                const recycleBin = getStorageList(STORAGE_KEYS.RECYCLE_BIN);
                groupedData = {};
                
                allData.forEach(item => {
                    const accountId = getAccountId(item);
                    if (recycleBin.includes(accountId)) return; 

                    const k = formatDateKey(item.created_at);
                    if(!groupedData[k]) groupedData[k] = [];
                    groupedData[k].push(item);
                });
                
                sortedDates = Object.keys(groupedData).sort((a,b) => b.localeCompare(a));
                
                // 完成
                progressBar.style.width = '100%';
                progressText.innerText = '100%';
                return true;

            } catch(e) { 
                console.error("数据加载出错:", e);
                throw e; 
            } finally {
                setTimeout(() => progressContainer.classList.remove('active'), 800);
            }
        }

        function init() {
            loadingEl.style.display = 'block';
            loadData().then(() => {
                if(sortedDates.length === 0) { loadingEl.innerText = "无数据"; return; }
                const newest = sortedDates[0];
                statsTotalEl.innerText = `共 ${allData.length.toLocaleString()} 视频`;
                statsNewestEl.style.display = 'inline-block';
                statsNewestEl.innerText = `✨ 最新 (${newest}) 更新 ${groupedData[newest].length} 部`;
                statsNewestEl.onclick = () => renderPage(newest);

                const saved = localStorage.getItem('lastDate');
                currentDateKey = (saved && sortedDates.includes(saved)) ? saved : newest;

                loadingEl.style.display = 'none';
                document.getElementById('pagination').style.display = 'flex';
                document.getElementById('top-pagination').style.display = 'flex';
                document.getElementById('bottom-manager-buttons').style.display = 'flex';
                
                renderPage(currentDateKey);
                setupEvents();
            }).catch(err => {
                loadingEl.innerHTML = `❌ 失败: ${err.message}<br><small>请检查网络连接或数据分片文件是否存在。</small>`;
                loadingEl.className = 'error';
            });
        }

        function renderPage(dateKey) {
            currentDateKey = dateKey;
            localStorage.setItem('lastDate', dateKey);
            gridEl.innerHTML = '';
            let items = groupedData[dateKey] || [];
            
            const favorites = getStorageList(STORAGE_KEYS.FAVORITES);
            if (favorites.length > 0) {
                items.sort((a, b) => {
                    const idA = getAccountId(a);
                    const idB = getAccountId(b);
                    const aFav = favorites.includes(idA);
                    const bFav = favorites.includes(idB);
                    if (aFav && !bFav) return -1;
                    if (!aFav && bFav) return 1;
                    return 0;
                });
            }

            if(items.length === 0) {
                gridEl.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:20px;">无数据</div>';
            } else {
                items.forEach(item => {
                    const a = document.createElement('a');
                    a.className = 'card'; a.href = item.url; a.target = '_blank';
                    
                    const accountId = getAccountId(item);
                    const displayName = accountId;
                    
                    const m = Math.floor((item.time||0)/60), s = (item.time||0)%60;
                    
                    const titleHtml = `<span class="account-link" onclick="event.preventDefault(); event.stopPropagation(); openAccountModal('${accountId}')">${displayName}</span>`;

                    a.innerHTML = `
                        <div class="thumb-container">
                            <img class="thumb-img" src="${item.thumbnail}" loading="lazy" onerror="this.src='https://via.placeholder.com/300x533?text=No+Image'">
                            <div class="duration-badge">${m}:${s.toString().padStart(2,'0')}</div>
                            <div class="play-overlay"><div class="play-icon">▶</div></div>
                        </div>
                        <div class="info">
                            <div class="title">${titleHtml}</div>
                            <div class="meta">
                                <span>👁️ ${formatNum(item.pv)}</span>
                                <span>❤️ ${formatNum(item.favorite)}</span>
                            </div>
                        </div>`;
                    gridEl.appendChild(a);
                });
            }
            updateUI();
            window.scrollTo({top: 0, behavior: 'smooth'});
        }

        function updateUI() {
            const idx = sortedDates.indexOf(currentDateKey);
            if (idx === -1) return;
            const count = groupedData[currentDateKey].length;
            
            [document.getElementById('page-date'), document.getElementById('top-page-date')].forEach(el => el.innerText = currentDateKey);
            [document.getElementById('page-count'), document.getElementById('top-page-count')].forEach(el => el.innerText = `${count} 部`);

            const hasNew = idx > 0, hasOld = idx < sortedDates.length - 1;
            [newerBtn, topNewerBtn].forEach(b => b.disabled = !hasNew);
            [olderBtn, topOlderBtn].forEach(b => b.disabled = !hasOld);

            if(hasNew) {
                const d = sortedDates[idx-1], c = groupedData[d].length;
                const txt = `⬅ ${d} (${c})`;
                newerBtn.innerText = txt; topNewerBtn.innerText = txt;
            } else {
                newerBtn.innerText = "已是最新"; topNewerBtn.innerText = "已是最新";
            }
            if(hasOld) {
                const d = sortedDates[idx+1], c = groupedData[d].length;
                const txt = `${d} (${c}) ➡`;
                olderBtn.innerText = txt; topOlderBtn.innerText = txt;
            } else {
                olderBtn.innerText = "已是最旧"; topOlderBtn.innerText = "已是最旧";
            }
        }

        function ensureCalendarPosition() {
            if(fpInstance && fpInstance.calendarContainer) fpInstance.calendarContainer.style.display = 'block';
        }

        function setupEvents() {
            const goNew = () => { const i=sortedDates.indexOf(currentDateKey); if(i>0) renderPage(sortedDates[i-1]); };
            const goOld = () => { const i=sortedDates.indexOf(currentDateKey); if(i<sortedDates.length-1) renderPage(sortedDates[i+1]); };
            
            newerBtn.onclick = goNew; olderBtn.onclick = goOld;
            topNewerBtn.onclick = goNew; topOlderBtn.onclick = goOld;

            const commonConfig = {
                locale: "zh", dateFormat: "Y-m-d", defaultDate: currentDateKey, theme: "dark",
                disable: [date => {
                    const y = date.getFullYear(), m = String(date.getMonth()+1).padStart(2,'0'), d = String(date.getDate()).padStart(2,'0');
                    return !sortedDates.includes(`${y}-${m}-${d}`);
                }],
                onChange: (selectedDates, dateStr) => {
                    if(dateStr && sortedDates.includes(dateStr)) { renderPage(dateStr); if(fpInstance) fpInstance.close(); }
                },
                position: "auto", static: true, appendTo: document.body
            };

            if(fpInstance) fpInstance.destroy();
            const hiddenInput = document.createElement('input');
            hiddenInput.style.display = 'none';
            document.body.appendChild(hiddenInput);
            fpInstance = flatpickr(hiddenInput, commonConfig);

            const openCalendar = (e) => {
                e.stopPropagation();
                if(fpInstance) { fpInstance.setDate(currentDateKey); fpInstance.open(); setTimeout(ensureCalendarPosition, 10); }
            };
            topDateTrigger.onclick = openCalendar;
            
            window.addEventListener('resize', () => { updateUI(); if(fpInstance && fpInstance.isOpen) ensureCalendarPosition(); });
            document.addEventListener('click', (e) => {
                if(fpInstance && fpInstance.isOpen && !e.target.closest('.flatpickr-calendar') && !e.target.closest('#top-date-trigger')) {
                    fpInstance.close();
                }
            });
        }

        function formatNum(n) {
            if(!n) return '0';
            n = parseInt(n);
            return n >= 1000000 ? (n/1e6).toFixed(1)+'M' : (n>=1000 ? (n/1e3).toFixed(1)+'k' : n);
        }
    </script>
</body>
</html>